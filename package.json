{
  "name": "paperclip-trello-sync",
  "version": "1.0.0",
  "description": "Bidirectional sync between Paperclip issues and Trello boards",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "sync": "ts-node src/cli.ts sync",
    "sync:board": "ts-node src/cli.ts board",
    "sync:webhook-setup": "ts-node src/cli.ts webhook-setup",
    "sync:webhook-teardown": "ts-node src/cli.ts webhook-teardown",
    "webhook": "node dist/webhook/webhook-server.js",
    "webhook:setup": "bash scripts/setup-webhook.sh",
    "webhook:teardown": "bash scripts/teardown-webhook.sh",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint src/"
  },
  "author": "CREED",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/creed-ai/paperclip-trello-sync.git"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/node-fetch": "^2.6.13",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "localtunnel": "^2.0.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "trello",
    "paperclip",
    "sync",
    "kanban",
    "project-management"
  ]
}
