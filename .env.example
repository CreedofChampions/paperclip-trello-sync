# Paperclip Configuration
# The API key is a JWT Bearer token, typically generated per-run by the Paperclip agent harness.
# For standalone usage, use `paperclipai agent local-cli <agent-id> --company-id <company-id>` to generate one.
PAPERCLIP_API_URL=http://localhost:3100/api
PAPERCLIP_COMPANY_ID=your-company-id
PAPERCLIP_API_KEY=your-paperclip-jwt-bearer-token
PAPERCLIP_RUN_ID=optional-run-id-for-mutation-tracing

# Trello Configuration
TRELLO_API_KEY=your-trello-api-key
TRELLO_API_SECRET=your-trello-api-secret
TRELLO_API_TOKEN=your-trello-token

# Sync Configuration
# Use the existing board ID to sync with an existing Trello board, or leave empty to create a new one.
TRELLO_BOARD_ID=
TRELLO_ORG_ID=your-trello-org-id
SYNC_INTERVAL_MS=30000

# Webhook Configuration
WEBHOOK_PORT=3101
WEBHOOK_BASE_URL=https://your-domain.com/trello/webhook